# E2E test credentials — copy to .env.e2e and fill in real values
# This file is safe to commit. .env.e2e is git-ignored.

# Tutor account (required for tutor-flow.spec.ts)
TEST_TUTOR_EMAIL=tutor@example.com
TEST_TUTOR_PASSWORD=yourpassword

# Manager account (required for manager-flow.spec.ts)
TEST_MANAGER_EMAIL=manager@example.com
TEST_MANAGER_PASSWORD=yourpassword

# Student account (required for student-flow.spec.ts, when created)
# TEST_STUDENT_EMAIL=student@example.com
# TEST_STUDENT_PASSWORD=yourpassword

# Override base URL (default: https://otutorhub.com)
# E2E_BASE_URL=http://localhost:5173
